{
  "mcpServers": {
    "ssh-exec": {
      "enabled": true,
      "owner": "admin",
      "command": "uvx",
      "args": [
        "mcp-science",
        "ssh-exec"
      ],
      "env": {
        "SSH_HOST": "10.2.0.3",
        "SSH_PORT": "22",
        "SSH_USERNAME": "oriol",
        "SSH_PRIVATE_KEY_FILE": "/app/ssh/id_rsa",
        "SSH_ALLOWED_COMMANDS": "ls,cat,head,tail,grep,find,ps,df,du,uptime,whoami,pwd,echo",
        "SSH_ALLOWED_PATHS": "/home,/tmp,/var/log",
        "SSH_COMMANDS_BLACKLIST": "rm,mv,dd,mkfs,fdisk,format,shutdown,reboot",
        "SSH_ARGUMENTS_BLACKLIST": "-rf,-fr,--force"
      }
    },
    "notion-mcp": {
      "enabled": true,
      "owner": "admin",
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "${OPENAPI_MCP_HEADERS}"
      }
    },
    "aws-resources-operations": {
      "enabled": true,
      "owner": "admin",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/baryhuang/mcp-server-aws-resources-python.git",
        "python",
        "-m",
        "mcp_server_aws_resources.server",
        "--region",
        "${AWS_REGION}"
      ],
      "env": {
        "AWS_ACCESS_KEY_ID": "${AWS_ACCESS_KEY_ID}",
        "AWS_SECRET_ACCESS_KEY": "${AWS_SECRET_ACCESS_KEY}",
        "AWS_SESSION_TOKEN": "${AWS_SESSION_TOKEN}",
        "AWS_DEFAULT_REGION": "${AWS_DEFAULT_REGION}"
      }
    },
    "filesystem": {
      "enabled": true,
      "owner": "admin",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/"
      ],
      "env": {}
    },
    "desktop-commander-mcp": {
      "enabled": true,
      "owner": "admin",
      "command": "npx",
      "args": [
        "-y",
        "@wonderwhy-er/desktop-commander"
      ],
      "env": {}
    },
    "playwright": {
      "enabled": true,
      "owner": "admin",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--no-sandbox",
        "--viewport-size",
        "1920x1080",
        "--output-dir",
        "/tmp",
        "--allow-unrestricted-file-access"
      ],
      "env": {}
    },
    "pickstar-2002-minio-mcp": {
      "enabled": true,
      "owner": "admin",
      "type": "stdio",
      "command": "npx",
      "args": [
        "@pickstar-2002/minio-mcp@latest",
        "--endpoint={{config.MINIO_ENDPOINT}}",
        "--port={{config.MINIO_PORT}}",
        "--access-key={{config.MINIO_ACCESS_KEY}}",
        "--secret-key={{config.MINIO_SECRET_KEY}}",
        "--use-ssl={{config.MINIO_USE_SSL}}",
        "--region={{config.MINIO_REGION}}"
      ],
      "config": {
        "MINIO_ENDPOINT": "minio",
        "MINIO_PORT": "9000",
        "MINIO_ACCESS_KEY": "minioadmin",
        "MINIO_SECRET_KEY": "minioadmin",
        "MINIO_USE_SSL": "false",
        "MINIO_REGION": "us-east-1"
      }
    }
  },
  "systemConfig": {
    "oauthServer": {
      "enabled": true,
      "accessTokenLifetime": 3600,
      "refreshTokenLifetime": 1209600,
      "authorizationCodeLifetime": 300,
      "requireClientSecret": false,
      "allowedScopes": [
        "read",
        "write"
      ],
      "requireState": false,
      "dynamicRegistration": {
        "enabled": true,
        "allowedGrantTypes": [
          "authorization_code",
          "refresh_token"
        ],
        "requiresAuthentication": false
      }
    },
    "smartRouting": {
      "enabled": false,
      "dbUrl": "",
      "openaiApiBaseUrl": "",
      "openaiApiKey": "",
      "openaiApiEmbeddingModel": ""
    },
    "routing": {
      "enableGlobalRoute": true,
      "enableGroupNameRoute": true,
      "enableBearerAuth": false,
      "bearerAuthKey": "",
      "skipAuth": false
    },
    "install": {
      "pythonIndexUrl": "",
      "npmRegistry": "",
      "baseUrl": "http://localhost:3000"
    },
    "mcpRouter": {
      "apiKey": "",
      "referer": "https://www.mcphubx.com",
      "title": "MCPHub",
      "baseUrl": "https://api.mcprouter.to/v1"
    },
    "enableSessionRebuild": true
  },
  "users": [
    {
      "username": "admin",
      "password": "$2b$10$Du6UuKrCKMhCfUbRIlDPE.ixXMmDfDzLw4hM0ac4y/VGB4.FJXS/e",
      "isAdmin": true
    }
  ],
  "bearerKeys": []
}