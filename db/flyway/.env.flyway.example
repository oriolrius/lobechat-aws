# Flyway provisioning secrets — copy to .env.flyway and fill values
# .env.flyway is gitignored. Vars ending in _B64 are base64-encoded multiline blobs.

# Casdoor SSO
CASDOOR_APP_LOBECHAT_CLIENT_SECRET=
CASDOOR_APP_BUILTIN_CLIENT_SECRET=
CASDOOR_USER_DEFAULT_PASSWORD=
CASDOOR_LDAP_BUILTIN_PASSWORD=
CASDOOR_CERT_BUILTIN_PRIVATE_KEY_B64=

# LobeChat encrypted ai_providers.key_vaults blobs (format: iv:salt:ciphertext)
# Generated by KEY_VAULTS_SECRET in main .env. If you rotate that secret these
# values become unreadable; re-enter API keys via UI to regenerate.
LOBECHAT_AIPROVIDER_GOOGLE_KEY_VAULTS=
LOBECHAT_AIPROVIDER_ANTHROPIC_KEY_VAULTS=
LOBECHAT_AIPROVIDER_VASTAI_KEY_VAULTS=
LOBECHAT_AIPROVIDER_OPENROUTER_KEY_VAULTS=
LOBECHAT_AIPROVIDER_VLLM_KEY_VAULTS=
