<mxfile host="app.diagrams.net" modified="2026-01-29" agent="Claude" version="24.7.17">
  <diagram id="release-workflow" name="Release Workflow Steps">
    <mxGraphModel dx="900" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Container -->
        <mxCell id="container" value="Release Workflow Steps" style="swimlane;html=1;startSize=40;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=16;rounded=1;arcSize=5;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="620" height="440" as="geometry"/>
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="step1" value="1. Checkout Repository" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="container">
          <mxGeometry x="40" y="60" width="540" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step1_desc" value="fetch-depth: 0 (full history for changelog)" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;spacingLeft=10;" vertex="1" parent="container">
          <mxGeometry x="50" y="85" width="520" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="step2" value="2. Get Previous Tag" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="container">
          <mxGeometry x="40" y="135" width="540" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step2_desc" value="git describe --tags --abbrev=0 HEAD^ — Used for changelog generation" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;spacingLeft=10;" vertex="1" parent="container">
          <mxGeometry x="50" y="160" width="520" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="step3" value="3. Generate Release Notes" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="container">
          <mxGeometry x="40" y="210" width="540" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step3_desc" value="git log &lt;prev_tag&gt;..&lt;new_tag&gt; — Creates &quot;What's Changed&quot; section" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;spacingLeft=10;" vertex="1" parent="container">
          <mxGeometry x="50" y="235" width="520" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="step4" value="4. Create Source Archives" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="container">
          <mxGeometry x="40" y="285" width="540" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step4_desc" value="git archive --format=zip / tar.gz" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;spacingLeft=10;" vertex="1" parent="container">
          <mxGeometry x="50" y="310" width="520" height="25" as="geometry"/>
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="step5" value="5. Create GitHub Release" style="rounded=1;arcSize=10;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=top;spacingTop=5;" vertex="1" parent="container">
          <mxGeometry x="40" y="360" width="540" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="step5_desc" value="Uses softprops/action-gh-release — Attaches archives and release notes" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;spacingLeft=10;" vertex="1" parent="container">
          <mxGeometry x="50" y="385" width="520" height="25" as="geometry"/>
        </mxCell>

        <!-- Arrows between steps -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#82b366;endArrow=classic;endFill=1;" edge="1" parent="container" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#82b366;endArrow=classic;endFill=1;" edge="1" parent="container" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#82b366;endArrow=classic;endFill=1;" edge="1" parent="container" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;curved=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2;strokeColor=#82b366;endArrow=classic;endFill=1;" edge="1" parent="container" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
