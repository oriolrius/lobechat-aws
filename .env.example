# Lobe Chat Configuration

# Not real secrets, just for test
# Generate with: openssl rand -base64 32
KEY_VAULTS_SECRET=Y2hhbmdlLW1lLWtleS12YXVsdHMtc2VjcmV0LTMyYg==
NEXT_AUTH_SECRET=Y2hhbmdlLW1lLW5leHRhdXRoLXNlY3JldC0zMmI=

# Host Configuration - Change this when deploying to different environment
HOST_DOMAIN=localhost

# Port Configuration
LOBECHAT_PORT=47000
CASDOOR_PORT=47002
POSTGRES_PORT=47003
MINIO_PORT=47005
MINIO_CONSOLE_PORT=47006
VLLM_PORT=47007
MCPHUB_PORT=47008

# Casdoor SSO Configuration
AUTH_CASDOOR_ID=your-casdoor-app-id
AUTH_CASDOOR_SECRET=your-casdoor-app-secret

# Casdoor Default Credentials (from init_data.json)
# Admin: admin / pswd123 (organization: built-in)
# User:  user / pswd123  (organization: lobechat)

# S3 Storage Configuration for Lobe Chat
S3_BUCKET=lobe

# PostgreSQL Configuration
POSTGRES_PASSWORD=change-me-postgres

# MinIO S3 Storage Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio

# OpenRouter API Configuration
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# vLLM Local Model Configuration
VLLM_MODEL_ID=oriolrius/myemoji-gemma-3-270m-it
VLLM_API_KEY=sk-local
HF_TOKEN=hf_your-huggingface-token

# MCPHub Configuration
MCPHUB_ADMIN_USER=admin
MCPHUB_ADMIN_PASSWORD=change-me-mcphub

# MCP SSH Exec Server Configuration
SSH_HOST=your-ssh-host
SSH_PORT=22
SSH_USERNAME=your-ssh-user
SSH_PRIVATE_KEY_FILE=/app/ssh/id_rsa
SSH_ALLOWED_COMMANDS=ls,cat,head,tail,grep,find,ps,df,du,uptime,whoami,pwd,echo
SSH_ALLOWED_PATHS=/home,/tmp,/var/log
SSH_COMMANDS_BLACKLIST=rm,mv,dd,mkfs,fdisk,format,shutdown,reboot
SSH_ARGUMENTS_BLACKLIST=-rf,-fr,--force

# AWS Credentials (optional - can mount ~/.aws instead)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token
AWS_REGION=eu-west-1
AWS_DEFAULT_REGION=eu-west-1
